generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Todo {
  id        String  @id
  clientId  String
  text      String
  completed Boolean @default(false)
  createdAt BigInt
  updatedAt BigInt
  deletedAt BigInt?

  @@index([clientId])
  @@index([updatedAt])
}
